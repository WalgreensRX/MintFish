# Discord Bot Token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_discord_bot_token_here

# Rust server RCON connection
RCON_HOST=your.server.ip
RCON_PORT=28016
RCON_PASSWORD=your_rcon_password

# Population scaling
# Server starts at POP_MIN slots.
# Every POP_STEP_SIZE players online, add POP_INCREMENT slots, up to POP_MAX.
#
# Example: MIN=50, MAX=200, STEP=10, INCREMENT=25
#   0-9 players  → 50 slots
#   10-19        → 75 slots
#   20-29        → 100 slots
#   (capped at 200)
POP_MIN=50
POP_MAX=200
POP_STEP_SIZE=10
POP_INCREMENT=25

# How often to poll the server (milliseconds). Default: 30 seconds.
POLL_INTERVAL_MS=30000

# Bot status text (customizable display language)
# Shown when the WebSocket connection to the server is down (Discord presence: red/dnd)
STATUS_OFFLINE=⛔ Server Offline
# Shown when connected to RCON but the game server hasn't finished starting yet (Discord presence: yellow/idle)
STATUS_STARTING=⏳ Server Starting...
# Shown during normal operation. Use {players} and {slots} as placeholders. (Discord presence: green/online)
STATUS_PLAYING=🎮 {players} / {slots} online
